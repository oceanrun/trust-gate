MOCK_MODE=true
WALLET_ADDRESS=0xYourWalletAddressHere
PORT=3000

# Coinbase CDP facilitator (required when MOCK_MODE=false)
# Get keys at https://portal.cdp.coinbase.com
CDP_API_KEY=
CDP_API_SECRET=

# RPC endpoints (public defaults work for light usage)
ETH_RPC_URL=https://ethereum.publicnode.com
BASE_RPC_URL=https://base.publicnode.com
